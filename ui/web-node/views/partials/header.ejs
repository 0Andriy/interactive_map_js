<% if (locals.showHeader !== false) { %>
<header class="app-header glass">
    <div style="display: flex; align-items: center; gap: 1rem;">
        <button id="mobileLeftToggle" class="schema-select" style="display: none;">☰</button>
        <div class="logo"><strong>CORE</strong> OS</div>
    </div>
    
    <div class="user-area" style="display: flex; align-items: center; gap: 1rem;">
        <div style="text-align: right; line-height: 1.2;">
            <div style="font-size: 0.9rem;"><%= locals.user?.name || 'Адмін' %></div>
            <div style="font-size: 0.7rem; color: var(--text-secondary);"><%= locals.user?.role || 'Оператор' %></div>
        </div>
        <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--accent-gradient);"></div>
    </div>
</header>
<% } %>